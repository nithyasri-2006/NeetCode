class Solution {
    public int lengthOfLastWord(String s) {
        
        int length = 0;

        // Start checking from the end of the string
        for (int i = s.length() - 1; i >= 0; i--) {
            
            if (s.charAt(i) != ' ') {
                length++;          // count characters
            } 
            else if (length > 0) {
                
                break;             // stop when space appears after counting
            }
        }

        return length;
    }
}
